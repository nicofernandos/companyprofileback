generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Menu {
  id        Int      @id @default(autoincrement())
  nama      String
  deskripsi String
  harga     Int
  gambar    String?
  createdAt DateTime @default(now())
}

model Admin { 
  id        Int @id @default(autoincrement())
  username  String @unique
  password  String
  createdAt DateTime @default(now())
}

model KategoriProduk {
  id        Int             @id @default(autoincrement())
  nama      String          
  
  produk    KatalogProduk[] 
}

model KatalogProduk {
  id             Int            @id @default(autoincrement())
  nama           String
  deskripsi      String
  harga          Int
  gambar         String?

  kategoriId     Int
  kategori       KategoriProduk @relation(fields: [kategoriId], references: [id])
  
  // Data pelengkap untuk tampilan React
  bahan          String         
  ulasan         Int            @default(0)
  rating         Float          @default(0.0)
  icon           String        
  
  badge          String?        
  badgeColor     String?      
  khasiat        String       

  createdAt      DateTime       @default(now())
}